# Dev migration env — copy to .env.migrate and fill in after `cdk deploy`
#
# export AWS_PROFILE=your-dev-profile
# export AWS_DEFAULT_REGION=us-east-1
#
# A11Y_BUCKET=pdfaccessibilitybucket1-xxxxxxxxxxxx
# STATE_MACHINE_ARN=arn:aws:states:us-east-1:264230611910:stateMachine:PdfAccessibilityRemediationWorkflow-...
# CHANNELS_DATA_BUCKET=channels-data-dev
# CHANNELS_CLOUDFRONT_DISTRIBUTION_ID=E27O7BO97BHXFO
#
# Local auto-chapters dry run:
#   ./scripts/migrate-channels-worksheets-a11y.sh \
#     --course-id biochemistry --env dev --auto-chapters --dry-run --skip-if-audited
#
# CodeBuild setup (once):
#   export GITHUB_URL=https://github.com/your-org/PDF_Accessibility_fork.git
#   ./scripts/create-migrate-codebuild-project.sh
#
# Ops notes:
#   - One CodeBuild run per course at a time (shared S3 progress file).
#   - CodeBuild needs GitHub OAuth for GITHUB_URL clone access.
#   - --skip-if-audited uses local tagged/alt checks only, not Adobe API.
