# CDK deploy env (Colima) — copy to .env.cdk and: source .env.cdk
#
# One-shot deploy (recommended):
#   ./scripts/cdk-deploy.sh
#
# Manual setup:
#   colima start
#   brew install docker colima   # docker CLI only, not Docker Desktop
#   brew link --overwrite docker # if docker command missing
#   docker context use colima
#   unset DOCKER_HOST            # let docker context drive the socket

export AWS_DEFAULT_REGION=us-east-1
export BUILDX_NO_DEFAULT_ATTESTATIONS=1

# Do not set DOCKER_HOST when using docker context colima.
# If you must:
# export DOCKER_HOST="unix://${HOME}/.colima/default/docker.sock"
